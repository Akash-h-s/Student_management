{
    "extends": "./tsconfig.app.json",
    "compilerOptions": {
        "composite": true,
        "noEmit": true,
        "types": [
            "vitest/globals",
            "@testing-library/jest-dom"
        ]
    },
    "include": [
        "src/**/*.test.ts",
        "src/**/*.test.tsx",
        "src/**/*.spec.ts",
        "src/**/*.spec.tsx",
        "src/setupTests.ts",
        "vitest.shims.d.ts"
    ]
}